# NMCScan Configuration

# Dashboard Authentication Key
# This must be sent in the X-API-Key header for API requests
API_KEY=changeme_secret_key

# Logging Level (debug, info, warn, error)
RUST_LOG=info

# External port to expose the dashboard/API on
PORT=3000

# Scanner Mode
# Set to true to only scan known test servers
TEST_MODE=false

# Public Contact Information (optional)
CONTACT_EMAIL=admin@yourdomain.com
DISCORD_LINK=https://discord.gg/yourserver

# NMCScan Configuration

# Dashboard Authentication Key
# This must be sent in the X-API-Key header for API requests
API_KEY=changeme_secret_key

# Logging Level (debug, info, warn, error)
RUST_LOG=info

# API Listen Address (internal to container)
LISTEN_ADDR=0.0.0.0:3000

# External port to expose the dashboard/API on
PORT=3000

# Scanner Mode
# Set to true to only scan known test servers
TEST_MODE=false

# Database Connection URL (PostgreSQL)
DATABASE_URL=postgres://nmcscan:nmcscan_secret@localhost:5432/nmcscan

# --- Scanner Performance Configuration ---

# Target requests per second (Connections Per Second)
TARGET_RPS=100

# Maximum simultaneous scanning tasks
TARGET_CONCURRENCY=2500

# Dedicated rate limit for residential/unknown ranges (Optional, defaults to 10% of TARGET_RPS)
# TARGET_COLD_RPS=10

# Path to the exclude configuration file
EXCLUDE_FILE=exclude.conf

# Scanner service URL (for API to communicate with scanner)
# In Docker: http://nmcscan-scanner:3001
# Local dev: http://localhost:3001
SCANNER_URL=http://localhost:3001

# --- Test Mode Configuration ---

# Set to true to only scan known test servers
TEST_MODE=false

# Maximum servers to scan in test mode
TEST_MAX_SERVERS=50

# Scan interval in seconds for test mode
TEST_SCAN_INTERVAL=60

# Region filter for test servers (comma-separated: us, eu, uk, au, br, asia)
# TEST_REGIONS=us,eu

# --- Public Information ---
CONTACT_EMAIL=admin@yourdomain.com
DISCORD_LINK=https://discord.gg/yourserver

# Authentication (Auth.js)
AUTH_SECRET=generate_a_random_secret_string_here
BACKEND_URL=http://localhost:3000
# Comma-separated list of emails allowed to log in
ALLOWED_USERS=your@email.com,friend@email.com
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
